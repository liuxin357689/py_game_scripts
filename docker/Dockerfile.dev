# ============================================
# Game Scripts - 开发环境 Dockerfile
# ============================================
# 用途: IDEA Ultimate Docker Interpreter 开发环境
# 构建: docker build -f docker/Dockerfile.dev -t game-scripts-dev .
# ============================================

FROM python:3.11-slim

# 安装系统依赖
RUN apt-get update && apt-get install -y \
    bash \
    && rm -rf /var/lib/apt/lists/*

# 设置工作目录
WORKDIR /app

# 安装 Python 依赖（从根目录 requirements.txt）
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 安装平台包（开发模式，支持热加载）
COPY platform/ ./platform/
RUN pip install --no-cache-dir -e ./platform/

# 安装开发工具
RUN pip install --no-cache-dir \
    pyinstaller \
    pytest \
    pytest-cov \
    black \
    pylint \
    debugpy

# 默认命令：保持容器运行（供 IDEA 连接）
CMD ["tail", "-f", "/dev/null"]
